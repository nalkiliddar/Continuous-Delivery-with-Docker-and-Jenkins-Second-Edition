pipeline {

    agent { 
        docker {
            image 'gradle:4.10.2'
            

        }
    }    
    options {
        // Blocks the automatic background connection step that was throwing the 403 error
        skipDefaultCheckout(true)
    }
    stages {
       
        stage('Checkout code') {
            steps { 
                git url: 'https://github.com/nalkiliddar/Continuous-Delivery-with-Docker-and-Jenkins-Second-Edition', branch: 'master'
                sh """
                cd Chapter08/sample1
                chmod +x gradlew
                """
            }
        }
        stage('Build') {
            steps {
                dir('Chapter08/sample1') { 
                    sh './gradlew clean tasks' 
                }
            }
        }  
        stage('prepare environment - Run CodeCoverage test on main branch') {
            when {
                anyOf {
                     branch 'master'
                     changeRequest target: 'master'
                }
            }         
            steps {
                dir('Chapter08/sample1') {
                    sh './gradlew test jacocoTestReport jacocoTestCoverageVerification' 

                }
            } 
        }    
        
        stage('Run jacocoTestReport checkstyleMain tests on the feature branch') {
            when { 
                anyOf {
                    branch 'feature'
                    changeRequest target: 'master'
                    
                }
            }         
            steps {
            sh """
                dir('Chapter08/sample1')
                
                ./gradlew jacocoTestReport checkstyleMain --continue 
            """
            }
            post {
                always {
                    publishHTML (
                        target: [
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'Chapter08/sample1/build/reports/tests/test',
                        reportFiles: 'index.html',
                        reportName: "JaCoCo Report"
                        ]
                    )
                    publishHTML (
                        target: [
                            allowMissing: false,
                            alwaysLinkToLastBuild: true,
                            keepAll: true,
                            reportDir: 'Chapter08/sample1/build/reports',
                            reportFiles: 'jacoco/test/html/index.html, checkstyle/main.html',
                            reportName: "jacoco checkstyle"
                        ]
                    )
                    }
            
                success {
                    echo "test pass!"
                }
                failure {
                    echo "test fail"
                }
            }   
        }  
    }
}          
          
          
               
          
       
    
    
       
   
