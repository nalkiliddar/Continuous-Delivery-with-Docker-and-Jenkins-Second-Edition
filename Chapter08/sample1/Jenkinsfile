pipeline {

    agent { 
        docker {
            image 'gradle:8.14.0-jdk21'
            

        }
    }    

    stages {
       
        stage('Checkout code and prepare environment') {
            steps {
                git url: 'https://github.com/nalkiliddar/Continuous-Delivery-with-Docker-and-Jenkins-Second-Edition', branch:'master'
                sh """
                cd Chapter08/sample1
                chmod +x gradlew
                """
            }
        }
        stage('Build') {
            steps {
                dir('Chapter08/sample1') { 
                    sh 'gradle build'
                }
            }
        }    
        stage('check Calculator.java Changes ') {
            when { 
                changeset '**/Calculator.java'
            }   
             steps {
                sh """
                  cd Chapter08/sample1
                  
                  ./gradlew jacocoTestReport checkstyleMain
                """
                publishHTML (
                    target: [
                      allowMissing: false,
                      alwaysLinkToLastBuild: true,
                      keepAll: true,
                      reportDir: 'Chapter08/sample1/build/reports/tests/test',
                      reportFiles: 'index.html',
                      reportName: "JaCoCo Report"
                    ]
                )
                publishHTML (
                      target: [
                          allowMissing: false,
                          alwaysLinkToLastBuild: true,
                          keepAll: true,
                          reportDir: 'Chapter08/sample1/build/reports',
                          reportFiles: 'jacoco/test/html/index.html, checkstyle/main.html',
                          reportName: "jacoco checkstyle"
                      ]
                  )
             }
         }
        stage('Run other Test') {
            steps {
                
                sh """
                cd Chapter08/sample1
                ./gradlew test
                
                """
                
                
            }
        }     
        
    }
    post {
        success {
            echo "pipeline ran perfectly"
        }
        failure {
            echo "pipeline failure"
        }
    }
}
